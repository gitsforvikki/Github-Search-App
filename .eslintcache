:0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"57","usedDeprecatedRules":"30"},"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\index.js",[],["58","59"],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\App.js",["60"],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\reportWebVitals.js",[],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\redux\\store.js",[],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\components\\GithubSearchApp.js",[],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\redux\\rootReducer.js",[],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\redux\\githubProfile\\githubSearch.action.js",[],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\components\\GithubProfile.js",[],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\components\\GithubRepos.js",["61"],"import React from 'react';\r\nimport {useSelector} from 'react-redux';\r\nimport * as githubSearchReducer from \"../redux/githubProfile/githubSearch.reducer\";\r\nimport spinner from '../assets/image/spinner.gif';\r\n\r\n\r\nlet GithubRepos =()=>{\r\n    //fetch data from redux store\r\n    let userInfo = useSelector((state)=>{\r\n        return state[githubSearchReducer.githubSearchFeaturesKey];\r\n    });\r\n\r\n    //destructuring\r\n    let {loading ,repos} = userInfo;\r\n    return(\r\n        <React.Fragment>\r\n            {\r\n                loading ?\r\n                    <React.Fragment>\r\n                        <img src={spinner} className=\"d-block m-auto\" alt=\"\"/>\r\n                    </React.Fragment> :\r\n                    <React.Fragment>\r\n                        <div className=\"card mt-3\">\r\n                            <div className=\"card-header\">\r\n                                <p className=\"leade\">Your Reposetories</p>\r\n                            </div>\r\n                            <div className=\"card-body\">\r\n                                <ul className=\"list-group\">\r\n                                    {\r\n                                        repos.map(repo=>{\r\n                                            return(\r\n                                                <React.Fragment>\r\n                                                    <li className=\"list-group-item\">\r\n                                                        <div className=\"d-flex justify-content-between\">\r\n                                                <span className=\"h5\">\r\n                                                    <a href={repo.html_url} target=\"_blank\">{repo.name}</a>\r\n                                                </span>\r\n                                                            <span className=\"badge badge-success\">{repo.stargazers_count} stars</span>\r\n                                                            <span className=\"badge badge-primary\">{repo.watchers_count} Watchers</span>\r\n\r\n                                                        </div>\r\n                                                    </li>\r\n                                                </React.Fragment>\r\n                                            )\r\n                                        })\r\n                                    }\r\n                                </ul>\r\n                            </div>\r\n                        </div>\r\n                    </React.Fragment>\r\n            }\r\n\r\n\r\n        </React.Fragment>\r\n    )\r\n};\r\nexport  default GithubRepos;","E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\redux\\githubProfile\\githubSearch.reducer.js",[],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\components\\GithubCredentials.js",[],"E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\components\\GithubProfileDetails.js",["62","63","64"],"import React from 'react';\r\nimport {useSelector} from 'react-redux';\r\nimport * as githubSearchReducer from '../redux/githubProfile/githubSearch.reducer';\r\n\r\nlet GithubProfileDetails =()=>{\r\n\r\n    //get data from redux store\r\n    let gitUserInfo = useSelector((state)=>{\r\n        return state[githubSearchReducer.githubSearchFeaturesKey];\r\n    });\r\n    let{loading ,profile } = gitUserInfo;\r\n\r\n\r\n    return(\r\n        <React.Fragment>\r\n            <div className=\"card mt-3\">\r\n                <div className=\"card-header\">\r\n                    <span  className=\"badge badge-primary mr-3\">{profile.followers}Followers</span>\r\n                    <span  className=\"badge badge-secondary mr-3\">{profile.public_repos}Repos </span>\r\n                    <span  className=\"badge badge-primary mr-3\">{profile.public_gists}Gist</span>\r\n                    <span  className=\"badge badge-primary mr-3\">{profile.following}Following</span>\r\n                </div>\r\n                <div className=\"card-body\">\r\n                    <div className=\"list-group\">\r\n                        <div className=\"list-group-item\">\r\n                            Name: <span className=\"font-weight-bold\">{profile.name}</span>\r\n                        </div>\r\n\r\n                        <div className=\"list-group-item\">\r\n                            Email: <span>{profile.email}</span>\r\n                        </div>\r\n                        <div className=\"list-group-item\">\r\n                            Location: <span>{profile.location}</span>\r\n                        </div>\r\n\r\n                        <div className=\"list-group-item\">\r\n                            Company: <span>{profile.company}</span>\r\n                        </div>\r\n\r\n                        <div className=\"list-group-item\">\r\n                            Blog: <span>\r\n                                <a href={profile.blog} target=\"_blank\">Blog</a>\r\n                            </span>\r\n                        </div>\r\n\r\n                        <div className=\"list-group-item\">\r\n                            Member since: <span>{profile.created_at}</span>\r\n                        </div>\r\n                        <div className=\"list-group-item\">\r\n                            Profile Url : <span >\r\n                                <a href={profile.html_url} target=\"_blank\">Profile</a>\r\n                            </span>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </React.Fragment>\r\n    )\r\n};\r\nexport  default GithubProfileDetails;","E:\\Workspace\\React_is_Workspace\\React-Basics-Module\\first-app\\src\\components\\GithubProfileCard.js",["65"],"import React from 'react';\r\nimport {useSelector} from 'react-redux';\r\nimport * as githubSearchReducer from \"../redux/githubProfile/githubSearch.reducer\";\r\nimport spinner from '../assets/image/spinner.gif';\r\nlet GithubProfileCard =()=>{\r\n\r\n    //fetch data from redux store\r\n    let userInfo = useSelector((state)=>{\r\n        return state[githubSearchReducer.githubSearchFeaturesKey];\r\n    });\r\n\r\n    //destructuring\r\n    let {loading , profile} = userInfo;\r\n\r\n\r\n    return(\r\n        <React.Fragment>\r\n            {\r\n                loading ?\r\n                    <React.Fragment>\r\n                        <img src={spinner} className=\"d-block m-auto\" alt=\"\"/>\r\n                    </React.Fragment> :\r\n                    <React.Fragment>\r\n                        <div className=\"card mt-3\">\r\n                            <img src={profile.avatar_url} alt=\"\" className=\"img-fluid\"/>\r\n                            <div className=\"card-body\">\r\n                                <p className=\"h3\">{profile.name}</p>\r\n                                <small>{profile.bio}</small>\r\n                                <a href={profile.html_url} target=\"_blank\" className=\"btn btn-success btn-sm\">Profile</a>\r\n                            </div>\r\n                        </div>\r\n                    </React.Fragment>\r\n            }\r\n        </React.Fragment>\r\n    )\r\n};\r\nexport  default GithubProfileCard;",{"ruleId":"66","replacedBy":"67"},{"ruleId":"68","replacedBy":"69"},{"ruleId":"70","severity":1,"message":"71","line":15,"column":21,"nodeType":"72","endLine":15,"endColumn":58},{"ruleId":"73","severity":1,"message":"74","line":36,"column":53,"nodeType":"72","endLine":36,"endColumn":93},{"ruleId":"75","severity":1,"message":"76","line":11,"column":9,"nodeType":"77","messageId":"78","endLine":11,"endColumn":16},{"ruleId":"73","severity":1,"message":"74","line":42,"column":33,"nodeType":"72","endLine":42,"endColumn":72},{"ruleId":"73","severity":1,"message":"74","line":51,"column":33,"nodeType":"72","endLine":51,"endColumn":76},{"ruleId":"73","severity":1,"message":"74","line":29,"column":33,"nodeType":"72","endLine":29,"endColumn":111},"no-native-reassign",["79"],"no-negated-in-lhs",["80"],"jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","no-unused-vars","'loading' is assigned a value but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation"]